{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "butter-scroll",
  "version": "0.2.0-pre.4",
  "identifier": "com.butter-scroll.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "butter-scroll 設定",
        "width": 520,
        "height": 680,
        "resizable": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwM0RBNjY0Njk2OEMyQTMKUldTandtaHBaS1k5Y0owekpEU1FNdGR3S3lCZnZUL1BNMmdUSDdiVldLOGJnbVpjQ1FMWHFRV3IK",
      "endpoints": [
        "https://github.com/maou-shonen/butter-scroll/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
